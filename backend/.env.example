# Async Postgres URL for your Supabase project.
# Supabase: Project Settings -> Database -> Connection string (URI), then swap
# the scheme to postgresql+asyncpg:// and use the connection-pooler host/port.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase: Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Comma-separated allowed CORS origins (your frontend URLs)
ALLOWED_ORIGINS=http://localhost:5173

# Optional overrides
JWT_AUDIENCE=authenticated
MAX_UPLOAD_BYTES=5242880
